<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/bookListFragment">

    <fragment
        android:id="@+id/bookListFragment"
        android:name="lb.edu.aub.cmps279Spring26.hmr23.ui.BookListFragment"
        android:label="Book Library"
        tools:layout="@layout/fragment_book_list">

        <action
            android:id="@+id/action_list_to_add"
            app:destination="@id/addBookFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />

        <action
            android:id="@+id/action_list_to_detail"
            app:destination="@id/bookDetailFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/addBookFragment"
        android:name="lb.edu.aub.cmps279Spring26.hmr23.ui.AddBookFragment"
        android:label="Add Book"
        tools:layout="@layout/fragment_add_book" />

    <fragment
        android:id="@+id/bookDetailFragment"
        android:name="lb.edu.aub.cmps279Spring26.hmr23.ui.BookDetailFragment"
        android:label="Book Details"
        tools:layout="@layout/fragment_book_detail">

        <action
            android:id="@+id/action_detail_to_edit"
            app:destination="@id/editBookFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/editBookFragment"
        android:name="lb.edu.aub.cmps279Spring26.hmr23.ui.EditBookFragment"
        android:label="Edit Book"
        tools:layout="@layout/fragment_edit_book" />

</navigation>
